---
import ThemeToggle from './ThemeToggle.astro';
---

<header class="border-b border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900">
  <div class="mx-auto flex w-full max-w-4xl items-center justify-between px-4 py-4">
    <a
      class="text-lg font-semibold tracking-tight text-slate-900 transition hover:text-slate-700 dark:text-slate-100 dark:hover:text-slate-300"
      href="/"
    >
      Lester Blog
    </a>

    <div class="flex items-center gap-3">
      <nav aria-label="Primary" class="text-sm text-slate-700 dark:text-slate-300">
        <a class="transition hover:text-slate-900 dark:hover:text-slate-100" href="/">Home</a>
      </nav>
      <ThemeToggle />
    </div>
  </div>
</header>
