---
import { getCollection, type CollectionEntry } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
  tag: string;
  posts: CollectionEntry<'blog'>[];
}

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const postsByTag = new Map<string, { label: string; posts: CollectionEntry<'blog'>[] }>();

  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      const normalizedTag = tag.trim().toLowerCase();
      if (!normalizedTag) {
        continue;
      }

      const existing = postsByTag.get(normalizedTag);
      if (existing) {
        existing.posts.push(post);
      } else {
        postsByTag.set(normalizedTag, {
          label: tag.trim(),
          posts: [post],
        });
      }
    }
  }

  return Array.from(postsByTag.entries()).map(([normalizedTag, value]) => ({
    params: { tag: normalizedTag },
    props: {
      tag: value.label,
      posts: value.posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { tag, posts } = Astro.props as Props;
---

<BaseLayout title={`#${tag} | Lester Blog`} description={`Posts tagged with ${tag}`}>
  <section class="space-y-2">
    <p class="text-sm font-medium text-slate-500">Tag</p>
    <h1 class="text-3xl font-bold tracking-tight">#{tag}</h1>
    <p class="text-slate-700">{posts.length} {posts.length === 1 ? 'post' : 'posts'} found.</p>
  </section>

  <ul class="mt-8 space-y-6">
    {posts.map((post) => (
      <li>
        <PostCard
          href={`/blog/${post.slug}/`}
          title={post.data.title}
          date={post.data.date}
          excerpt={post.data.description}
          tags={post.data.tags}
        />
      </li>
    ))}
  </ul>
</BaseLayout>
